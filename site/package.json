{
    "name": "site",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "d1:create": "wrangler d1 create slingshot-feedback",
        "d1:migrate": "wrangler d1 execute slingshot-feedback --remote --file=./functions/schemas/001_feedback.sql",
        "d1:studio": "wrangler d1 execute slingshot-feedback --remote --command='SELECT * FROM feedback ORDER BY created_at DESC LIMIT 50'"
    },
    "dependencies": {
        "@nuxtjs/sitemap": "^8.2.2",
        "nuxt": "^4.4.8",
        "vue": "^3.5.39",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.3.2",
        "tailwindcss": "^4.3.2",
        "wrangler": "^4.110.0"
    }
}
